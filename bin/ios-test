#!/bin/bash
set -e
set -o pipefail

cd "$(dirname "$0")/../hauptgang-ios"

echo "==> Finding available iPhone simulator..."
SIMULATOR_ID=$(xcrun simctl list devices available | grep "iPhone" | head -1 | grep -oE "[A-F0-9-]{36}")

if [ -z "$SIMULATOR_ID" ]; then
  echo "Error: No iPhone simulator found. Install one via Xcode."
  exit 1
fi

SIMULATOR_NAME=$(xcrun simctl list devices available | grep "$SIMULATOR_ID" | sed 's/.*\(iPhone[^(]*\).*/\1/' | xargs)
echo "    Using: $SIMULATOR_NAME ($SIMULATOR_ID)"

echo "==> Regenerating Xcode project..."
xcodegen generate

echo "==> Running iOS tests..."
LOG_FILE=$(mktemp /tmp/ios-test.XXXXXX.log)
if xcodebuild -project Hauptgang.xcodeproj -scheme Hauptgang \
  -destination "platform=iOS Simulator,id=$SIMULATOR_ID" \
  test 2>&1 | tee "$LOG_FILE" | grep -E "(Test Suite|passed|failed|BUILD|TEST)"; then
  echo "==> Done!"
  exit 0
fi

echo "==> xcodebuild failed. Key error lines:"
rg -n "error:|FAILED|Testing cancelled|The following build commands failed|BUILD FAILED|TEST FAILED" "$LOG_FILE" || true
echo "==> Full log: $LOG_FILE"
exit 1
