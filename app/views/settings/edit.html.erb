<% content_for :title, "Settings" %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-2xl mx-auto px-6 py-10">
    <h1 class="font-serif text-2xl font-bold text-text-primary dark:text-gray-100 mb-1">Settings</h1>
    <p class="text-sm text-text-secondary dark:text-gray-400 mb-8">
      Update how you appear in shared cookbooks.
    </p>

    <% if notice.present? %>
      <div class="mb-6 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-200 text-sm">
        <%= notice %>
      </div>
    <% end %>

    <% if @user.errors.any? %>
      <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-700 dark:text-red-200 text-sm">
        <ul class="list-disc list-inside space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-surface-overlay dark:bg-gray-800 rounded-xl shadow-sm border border-border-subtle dark:border-gray-700 p-6">
      <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-4" do |form| %>
        <div>
          <label for="user_name" class="block text-sm font-medium text-text-primary dark:text-gray-200 mb-1">
            Name
          </label>
          <%= form.text_field :name,
              required: true,
              autocomplete: "name",
              placeholder: "Your name",
              class: "w-full bg-surface-overlay dark:bg-gray-800 p-3 rounded-lg border border-gray-200 dark:border-gray-700 focus:border-brand-primary dark:focus:border-amber-600 focus:ring-1 focus:ring-brand-primary dark:focus:ring-amber-600 focus:outline-none transition-all text-text-primary dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500" %>
          <p class="text-xs text-text-tertiary dark:text-gray-500 mt-1">
            Shown to other members of cookbooks you share, including in push notifications.
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-text-primary dark:text-gray-200 mb-1">Email</label>
          <div class="text-sm text-text-secondary dark:text-gray-400"><%= @user.email_address %></div>
        </div>

        <%= form.submit "Save changes",
            class: "bg-brand-primary hover:bg-brand-primary-dark dark:bg-amber-700 dark:hover:bg-amber-800 text-white py-2 px-4 rounded-lg font-medium shadow-sm hover:shadow-md transition-all cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
