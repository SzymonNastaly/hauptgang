<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hauptgang" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag "icon.png" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body id="body">
    <div data-controller="mobile-nav" class="h-screen w-full bg-surface-base dark:bg-gray-950 grain-texture flex flex-col md:flex-row overflow-hidden">
      <%= render "layouts/mobile_sidebar_drawer" %>
      <%= render "layouts/sidebar" %>

      <main class="flex-1 flex flex-col min-w-0 h-full bg-surface-base dark:bg-gray-950">
        <%= yield %>
      </main>
    </div>


  </body>
</html>
